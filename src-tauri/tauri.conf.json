{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Attack Shark",
  "version": "1.0.0",
  "identifier": "io.attackshark.driver",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../ui",
    "beforeBuildCommand": "npm run build --prefix ../ui",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Attack Shark",
        "width": 1120,
        "height": 720,
        "minWidth": 920,
        "minHeight": 620,
        "resizable": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "SterTheStar",
    "copyright": "Copyright (c) 2026 SterTheStar",
    "shortDescription": "Configure Attack Shark mice",
    "longDescription": "A Linux userspace driver and desktop configuration app for Attack Shark mice.",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/256x256.png", "icons/512x512.png", "icons/icon.icns"]
  }
}
