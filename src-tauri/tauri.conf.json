{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Attack Shark",
  "version": "1.0.1",
  "identifier": "io.attackshark.driver",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../ui",
    "beforeBuildCommand": "npm run build --prefix ../ui",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Attack Shark",
        "width": 1120,
        "height": 720,
        "minWidth": 920,
        "minHeight": 620,
        "resizable": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": { "active": true, "targets": "all", "icon": [] }
}
